{
  "uischema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/deviceScheme",
        "label": "Protocol",
        "options": {
          "radio": true
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/deviceHostname",
        "label": "Device Hostname"
      }
    ]
  },
  "dataschema": {
    "type": "object",
    "properties": {
      "deviceScheme": {
        "type": "string",
        "enum": [
          "https",
          "http"
        ],
        "default": "https"
      },
      "deviceHostname": {
        "type": "string",
        "anyOf": [
          {
            "format": "hostname"
          },
          {
            "format": "ipv4"
          }
        ],
        "default": "192.168.1.100",
        "description": "e.g. ie-device-001.company.com or 192.168.1.100"
      }
    },
    "required": [
      "deviceScheme",
      "deviceHostname"
    ]
  }
}
