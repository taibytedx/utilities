    <md:AssertionConsumerService index="1" isDefault="true" 
      Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST" Location="http://localhost:45245/config/login/idp"/>
  </md:SPSSODescriptor>
